{
  "name": "browserclaw",
  "version": "0.15.2",
  "description": "AI-friendly browser automation with snapshot + ref targeting. No CSS selectors, no XPath, no vision — just numbered refs.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    ".claude/skills/browserclaw/SKILL.md"
  ],
  "scripts": {
    "build": "tsup && node -e \"import('./dist/index.js')\"",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "check-exports": "npx tsx scripts/check-exports.ts",
    "prepublishOnly": "npm run build && npx tsx scripts/check-exports.ts",
    "test": "vitest run"
  },
  "keywords": [
    "browser",
    "automation",
    "playwright",
    "ai",
    "snapshot",
    "accessibility",
    "aria",
    "cdp",
    "chrome",
    "web-scraping",
    "agent",
    "llm"
  ],
  "author": "Idan Rubin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/idan-rubin/browserclaw.git"
  },
  "homepage": "https://github.com/idan-rubin/browserclaw#readme",
  "bugs": {
    "url": "https://github.com/idan-rubin/browserclaw/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "ipaddr.js": "^2.3.0",
    "playwright-core": "^1.50.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.1",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2"
  }
}
